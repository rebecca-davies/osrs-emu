#!/usr/bin/env bash
# Git does not install repository hooks automatically. Run scripts/install-local-hooks.sh once.
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
if [ "$(git -C "$ROOT" branch --show-current)" != "main" ]; then
  exit 0
fi

LOG_FILE="${XDG_STATE_HOME:-$HOME/.local/state}/osrsemu/local-cd.log"
mkdir -p "$(dirname "$LOG_FILE")"
echo "osrsemu local CD starting; log: $LOG_FILE"
# Run synchronously: Git/tooling supervisors are allowed to reap detached hook children as soon as
# the merge process exits, which can turn a background deploy into a silent no-op.
"$ROOT/scripts/run-local-cd.sh" 2>&1 | tee "$LOG_FILE"
